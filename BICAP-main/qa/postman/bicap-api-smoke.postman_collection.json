{
  "info": {
    "name": "BICAP API Smoke",
    "_postman_id": "f0c7e6da-eaa5-4f40-b75e-650104758879",
    "description": "Smoke tests for BICAP backend services after Docker deployment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/api/auth/login",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login should succeed', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const rawToken = pm.response.text().trim();",
              "const token = rawToken.replace(/^\"|\"$/g, '');",
              "",
              "pm.test('Token should not be empty', function () {",
              "    pm.expect(token).to.not.eql('');",
              "});",
              "",
              "pm.environment.set('admin_token', token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Service - Dashboard Stats",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{admin_base_url}}/api/v1/admin/dashboard/stats",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "dashboard",
            "stats"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const failureScenario = pm.environment.get('QA_FAILURE_SCENARIO') || 'none';",
              "",
              "pm.test('Dashboard stats should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "",
              "pm.test('Dashboard stats should include totals', function () {",
              "    pm.expect(jsonData).to.have.property('totalUsers');",
              "    pm.expect(jsonData).to.have.property('totalFarms');",
              "    pm.expect(jsonData).to.have.property('totalOrders');",
              "});",
              "",
              "if (failureScenario === 'backend_a') {",
              "    pm.test('Backend scenario backend_a should expose totalWarehouses', function () {",
              "        pm.expect(jsonData).to.have.property('totalWarehouses');",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Service - Get All Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{admin_base_url}}/api/v1/admin/users/all",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "all"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get all users should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Get all users should return an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Shipping Service - Get Vehicles",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{shipping_base_url}}/api/vehicles",
          "host": [
            "{{shipping_base_url}}"
          ],
          "path": [
            "api",
            "vehicles"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get vehicles should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Get vehicles should return an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Shipping Service - Get Drivers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{shipping_base_url}}/api/drivers",
          "host": [
            "{{shipping_base_url}}"
          ],
          "path": [
            "api",
            "drivers"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const failureScenario = pm.environment.get('QA_FAILURE_SCENARIO') || 'none';",
              "",
              "pm.test('Get drivers should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Get drivers should return an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "",
              "if (failureScenario === 'backend_b') {",
              "    pm.test('Backend scenario backend_b should return non-empty driverCode on first entry', function () {",
              "        const drivers = pm.response.json();",
              "        pm.expect(drivers[0]).to.have.property('driverCode');",
              "        pm.expect(drivers[0].driverCode).to.eql('QA-EXPECTED-DRIVER-CODE');",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Service - Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{admin_refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/api/auth/refresh",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const failureScenario = pm.environment.get('QA_FAILURE_SCENARIO') || 'none';",
              "",
              "pm.test('Refresh token should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "if (failureScenario === 'backend_c') {",
              "    pm.test('Backend scenario backend_c: refresh token should return valid accessToken', function () {",
              "        const jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property('accessToken');",
              "        pm.expect(jsonData.accessToken).to.not.be.empty;",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Service - User List Pagination",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{admin_base_url}}/api/v1/admin/users?page=1&limit=10",
          "host": [
            "{{admin_base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const failureScenario = pm.environment.get('QA_FAILURE_SCENARIO') || 'none';",
              "",
              "pm.test('User list should return 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('User list should return an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});",
              "",
              "if (failureScenario === 'backend_d') {",
              "    pm.test('Backend scenario backend_d: user list should include pagination metadata', function () {",
              "        const jsonData = pm.response.json();",
              "        pm.expect(jsonData).to.have.property('meta');",
              "        pm.expect(jsonData.meta).to.have.property('total');",
              "        pm.expect(jsonData.meta).to.have.property('page');",
              "        pm.expect(jsonData.meta).to.have.property('limit');",
              "    });",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
