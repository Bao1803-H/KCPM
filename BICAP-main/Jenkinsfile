def runCmd(String command) {
    if (!command) {
        error("runCmd received null or empty command")
    }
    if (isUnix()) {
        sh(script: command)
    } else {
        powershell(script: command)
    }
}

def inProjectDir(Closure body) {
    dir('BICAP-main') {
        body()
    }
}

def writeProjectFile(String path, String content) {
    inProjectDir {
        writeFile(file: path, text: content)
    }
}

String extractJiraKey(String branchName) {
    if (!branchName) {
        return null
    }

    def matcher = (branchName =~ /([A-Z][A-Z0-9]+-\d+)/)
    if (matcher.find()) {
        return matcher.group(1)
    }

    return null
}

def runNpm(String args) {
    if (!args) {
        error("runNpm received null or empty args")
    }
    if (isUnix()) {
        sh(script: "npm ${args}")
    } else {
        powershell(script: "npm.cmd ${args}")
    }
}

def runNpx(String args) {
    if (!args) {
        error("runNpx received null or empty args")
    }
    if (isUnix()) {
        sh(script: "npx ${args}")
    } else {
        powershell(script: "npx.cmd ${args}")
    }
}

def ensureDir(String path) {
    if (!path) {
        error("ensureDir received null or empty path")
    }
    if (isUnix()) {
        sh(script: "mkdir -p ${path}")
    } else {
        powershell(script: "New-Item -ItemType Directory -Force '${path}' | Out-Null")
    }
}

def reportJiraBug(String module, String stageName, String reportFile) {
    if (!module || !stageName || !reportFile) {
        echo "Skipping reportJiraBug: missing required parameters (module=${module}, stage=${stageName}, file=${reportFile})"
        return
    }
    def escapedStage = stageName.replace('"', '\\"')
    def escapedFile = reportFile.replace('"', '\\"')
    def escapedModule = module.replace('"', '\\"')
    inProjectDir {
        runCmd("node automation/jira/create-jira-bug.mjs --module ${escapedModule} --stage \"${escapedStage}\" --descriptionFile \"${escapedFile}\"")
    }
}

String detectServiceFromError(String errorText) {
    if (!errorText) {
        return null
    }

    def lowerError = errorText.toLowerCase()

    // Frontend services detection
    if (lowerError.contains('guest')) return 'guest-web'
    if (lowerError.contains('farm')) return 'farm-management-web'
    if (lowerError.contains('admin') && lowerError.contains('web')) return 'admin-web'
    if (lowerError.contains('retailer')) return 'retailer-web'
    if (lowerError.contains('shipping') && lowerError.contains('manager')) return 'shipping-manager-web'

    // Backend services detection
    if (lowerError.contains('auth')) return 'auth-service'
    if (lowerError.contains('admin') && lowerError.contains('service')) return 'admin-service'
    if (lowerError.contains('shipping') && lowerError.contains('service')) return 'shipping-manager-service'
    if (lowerError.contains('dashboard')) return 'admin-service'
    if (lowerError.contains('vehicle')) return 'shipping-manager-service'
    if (lowerError.contains('driver')) return 'shipping-manager-service'
    if (lowerError.contains('user')) return 'admin-service'

    // Generic fallback based on error patterns
    if (lowerError.contains('login') || lowerError.contains('register')) return 'guest-web'
    if (lowerError.contains('health')) return 'farm-management-web'
    if (lowerError.contains('token')) return 'auth-service'

    return null
}

def transitionJiraIssue(String issueKey, String statusName) {
    if (!issueKey) {
        echo "Skipping Jira transition because issue key is empty."
        return
    }

    def escapedStatus = statusName.replace('"', '\\"')
    inProjectDir {
        runCmd("node automation/jira/update-jira-status.mjs --issueKey ${issueKey} --status \"${escapedStatus}\"")
    }
}

List composeServicesForScope(String scope) {
    switch (scope) {
        case 'frontend':
            return ['guest-web', 'retailer-web', 'admin-web', 'farm-management-web', 'shipping-manager-web']
        case 'backend':
            return ['auth-service', 'admin-service', 'shipping-manager-service']
        case 'integration':
            return [
                'guest-web',
                'retailer-web',
                'admin-web',
                'farm-management-web',
                'shipping-manager-web',
                'auth-service',
                'admin-service',
                'shipping-manager-service'
            ]
        case 'infra':
        case 'all':
        default:
            return []
    }
}

String composeUpCommand(String scope) {
    def services = composeServicesForScope(scope)
    return services
        ? "docker compose up -d --build ${services.join(' ')}"
        : 'docker compose up -d --build'
}

String qaTargetsForScope(String scope) {
    def guestPort = '3405'
    def farmPort = '3402'
    def adminPort = '3401'
    def retailerPort = '3400'
    def shippingManagerPort = '3403'

    switch (scope) {
        case 'frontend':
            return "http://127.0.0.1:${guestPort}/login http://127.0.0.1:${farmPort}/health http://127.0.0.1:${adminPort}/login http://127.0.0.1:${retailerPort}/login http://127.0.0.1:${shippingManagerPort}/login"
        case 'backend':
            return 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
        case 'infra':
            return 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
        case 'integration':
        case 'all':
        default:
            return "tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:${guestPort}/login http://127.0.0.1:${farmPort}/health http://127.0.0.1:${adminPort}/login http://127.0.0.1:${retailerPort}/login http://127.0.0.1:${shippingManagerPort}/login"
    }
}

String jiraModuleForScope(String scope) {
    switch (scope) {
        case 'frontend':
            return 'frontend'
        case 'backend':
            return 'backend'
        case 'integration':
        case 'all':
            return 'integration'
        case 'infra':
        default:
            return 'infra'
    }
}

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'QA_SCOPE',
            choices: ['all', 'frontend', 'backend', 'integration', 'infra'],
            description: 'Select the QA scope that the tester wants Jenkins to run.'
        )
        choice(
            name: 'QA_FAILURE_SCENARIO',
            choices: ['none', 'frontend_a', 'frontend_b', 'frontend_c', 'frontend_d', 'frontend_e', 'backend_a', 'backend_b', 'backend_c', 'backend_d'],
            description: 'Optional failure scenario to simulate a specific bug assignment during QA.'
        )
    }

    environment {
        QA_REPORT_DIR = 'qa/reports'
        QA_FAILURE_SCENARIO = "${params.QA_FAILURE_SCENARIO}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Reports') {
            steps {
                script {
                    inProjectDir {
                        ensureDir(env.QA_REPORT_DIR)
                    }
                }
            }
        }

        stage('Scope Summary') {
            steps {
                script {
                    def scope = params.get('QA_SCOPE', 'all')?.toString()?.trim() ?: 'all'

                    echo "DEBUG scope: '${scope}'"

                    if (scope == 'frontend') {
                        env.QA_TARGETS = 'http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                        env.QA_DEPLOY_COMMAND = 'docker compose up -d --build guest-web retailer-web admin-web farm-management-web shipping-manager-web'
                        env.QA_SCOPE_MODULE = 'frontend'
                        env.QA_SERVICE_LIST = 'guest-web, retailer-web, admin-web, farm-management-web, shipping-manager-web'
                    } else if (scope == 'backend') {
                        env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
                        env.QA_DEPLOY_COMMAND = 'docker compose up -d --build auth-service admin-service shipping-manager-service'
                        env.QA_SCOPE_MODULE = 'backend'
                        env.QA_SERVICE_LIST = 'auth-service, admin-service, shipping-manager-service'
                    } else if (scope == 'integration') {
                        env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                        env.QA_DEPLOY_COMMAND = 'docker compose up -d --build guest-web retailer-web admin-web farm-management-web shipping-manager-web auth-service admin-service shipping-manager-service'
                        env.QA_SCOPE_MODULE = 'integration'
                        env.QA_SERVICE_LIST = 'guest-web, retailer-web, admin-web, farm-management-web, shipping-manager-web, auth-service, admin-service, shipping-manager-service'
                    } else if (scope == 'infra') {
                        env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
                        env.QA_DEPLOY_COMMAND = 'docker compose up -d --build'
                        env.QA_SCOPE_MODULE = 'infra'
                        env.QA_SERVICE_LIST = 'full-stack'
                    } else {
                        env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                        env.QA_DEPLOY_COMMAND = 'docker compose up -d --build'
                        env.QA_SCOPE_MODULE = 'integration'
                        env.QA_SERVICE_LIST = 'full-stack'
                    }

                    echo "Selected QA scope: ${scope}"
                    echo "QA_TARGETS: ${env.QA_TARGETS}"
                    echo "QA_DEPLOY_COMMAND: ${env.QA_DEPLOY_COMMAND}"
                    echo "QA_SCOPE_MODULE: ${env.QA_SCOPE_MODULE}"
                }
            }
        }

        stage('Mark Jira In Progress') {
            when {
                expression {
                    return extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH) != null
                }
            }
            steps {
                script {
                    def jiraKey = extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH)
                    transitionJiraIssue(jiraKey, env.JIRA_STATUS_IN_PROGRESS ?: 'In Progress')
                }
            }
        }

        stage('Deploy Test Stack') {
            steps {
                script {
                    def deployCmd = env.QA_DEPLOY_COMMAND
                    if (!deployCmd) {
                        error("QA_DEPLOY_COMMAND is null or empty. QA_SCOPE=${params.QA_SCOPE}")
                    }
                    echo "Executing deploy: ${deployCmd}"
                    try {
                        inProjectDir {
                            // Check Docker is available
                            runCmd("docker --version")
                            runCmd("docker compose version")
                            // List current containers
                            runCmd("docker compose ps")
                            // Run deploy
                            runCmd(deployCmd)
                            // Wait longer for containers to fully start (web apps need more time)
                            echo "Waiting 60 seconds for services to be ready..."
                            sleep 60
                            // Check containers after deploy
                            runCmd("docker compose ps")
                        }
                    } catch (err) {
                        def errorMsg = err.toString()
                        def detectedService = detectServiceFromError(errorMsg)
                        def moduleToReport = detectedService ?: (env.QA_SCOPE_MODULE ?: 'integration')
                        def reportFile = "${env.QA_REPORT_DIR}/deploy-failure.txt"
                        writeProjectFile(
                            reportFile,
                            """Stage: Deploy Test Stack
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Selected Scope: ${params.QA_SCOPE ?: 'all'}
Deploy Command: ${deployCmd}
Error: ${err}
"""
                        )
                        reportJiraBug(moduleToReport, 'Deploy Test Stack', reportFile)
                        throw err
                    }
                }
            }
        }

        stage('Wait For Targets') {
            steps {
                script {
                    def targets = env.QA_TARGETS
                    echo "Waiting for targets: ${targets}"
                    try {
                        inProjectDir {
                            // Check Docker containers status
                            runCmd("docker compose ps")
                            // Run wait for targets with longer timeout
                            withEnv(["QA_WAIT_TIMEOUT_MS=300000"]) {
                                runCmd("node qa/scripts/wait-for-targets.mjs ${targets}")
                            }
                        }
                    } catch (err) {
                        def errorMsg = err.toString()
                        def detectedService = detectServiceFromError(errorMsg)
                        def moduleToReport = detectedService ?: (env.QA_SCOPE_MODULE ?: 'integration')
                        // Capture container logs on failure
                        try {
                            runCmd("docker compose logs --tail=50")
                        } catch (logErr) {
                            echo "Could not capture logs: ${logErr}"
                        }
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/wait-targets-failure.txt",
                            """Stage: Wait For Targets
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Selected Scope: ${params.QA_SCOPE ?: 'all'}
Targets: ${targets}
Error: ${err}
"""
                        )
                        reportJiraBug(moduleToReport, 'Wait For Targets', "${env.QA_REPORT_DIR}/wait-targets-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Infrastructure QA') {
            when {
                expression {
                    return params.QA_SCOPE == 'infra'
                }
            }
            steps {
                script {
                    try {
                        inProjectDir {
                            runCmd('docker compose ps')
                        }
                    } catch (err) {
                        def errorMsg = err.toString()
                        def detectedService = detectServiceFromError(errorMsg)
                        def moduleToReport = detectedService ?: 'infra'
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/infra-failure.txt",
                            """Stage: Infrastructure QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Selected scope: ${params.QA_SCOPE}
Error: ${err}
"""
                        )
                        reportJiraBug(moduleToReport, 'Infrastructure QA', "${env.QA_REPORT_DIR}/infra-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Frontend QA') {
            when {
                expression {
                    return params.QA_SCOPE in ['all', 'frontend', 'integration']
                }
            }
            steps {
                script {
                    def services = ['guest-web', 'retailer-web', 'admin-web', 'farm-management-web', 'shipping-manager-web']
                    def failedServices = []

                    inProjectDir {
                        runNpm('install --prefix clients/web-app/shipping-manager-web')
                        runNpm('run build --prefix clients/web-app/shipping-manager-web')
                        runNpm('install --prefix clients/web-app/farm-management-web')
                        runNpm('run test:smoke --prefix clients/web-app/farm-management-web')

                        // Run each frontend check individually
                        try {
                            runCmd('node qa/scripts/frontend-smoke.mjs')
                        } catch (err) {
                            // Parse which service failed from error output
                            def errorMsg = err.toString()
                            def failedService = detectServiceFromError(errorMsg)
                            failedServices << failedService

                            writeProjectFile(
                                "${env.QA_REPORT_DIR}/frontend-failure.txt",
                                """Stage: Frontend QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Failed Service: ${failedService}
Error: ${err}
"""
                            )
                            reportJiraBug(failedService, 'Frontend QA', "${env.QA_REPORT_DIR}/frontend-failure.txt")
                            throw err
                        }
                    }
                }
            }
        }

        stage('Backend QA') {
            when {
                expression {
                    return params.QA_SCOPE in ['all', 'backend', 'integration']
                }
            }
            steps {
                script {
                    inProjectDir {
                        try {
                            withEnv(["QA_FAILURE_SCENARIO=${params.QA_FAILURE_SCENARIO}"]) {
                                runNpx('--yes newman run qa/postman/bicap-api-smoke.postman_collection.json -e qa/postman/local.postman_environment.json --reporters cli,junit --reporter-junit-export qa/reports/newman-results.xml')
                            }
                        } catch (err) {
                            // Parse Newman output to identify failed service
                            def errorMsg = err.toString()
                            def failedService = detectServiceFromError(errorMsg)

                            writeProjectFile(
                                "${env.QA_REPORT_DIR}/backend-failure.txt",
                                """Stage: Backend QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Failed Service: ${failedService}
Error: ${err}
"""
                            )
                            reportJiraBug(failedService, 'Backend QA', "${env.QA_REPORT_DIR}/backend-failure.txt")
                            throw err
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'BICAP-main/qa/reports/*.xml'
                }
            }
        }
    }

    post {
        success {
            script {
                def jiraKey = extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH)
                if (jiraKey) {
                    transitionJiraIssue(jiraKey, env.JIRA_STATUS_READY_FOR_RETEST ?: 'Ready for Retest')
                }
            }
        }
        always {
            script {
                def currentBranch = env.BRANCH_NAME ?: env.GIT_BRANCH ?: ''
                def isMainBranch = currentBranch == 'main' || currentBranch == 'origin/main' || currentBranch.endsWith('/main')

                if (isMainBranch) {
                    echo 'Skipping docker compose down on main branch to avoid stopping the shared QA stack.'
                } else {
                    try {
                        inProjectDir {
                            runCmd('docker compose down -v')
                        }
                    } catch (err) {
                        echo "docker compose down failed: ${err}"
                    }
                }
            }
            archiveArtifacts allowEmptyArchive: true, artifacts: 'BICAP-main/qa/reports/**/*'
        }
    }
}
