def runCmd(String command) {
    if (isUnix()) {
        sh(script: command)
    } else {
        powershell(script: command)
    }
}

def inProjectDir(Closure body) {
    dir('BICAP-main') {
        body()
    }
}

def writeProjectFile(String path, String content) {
    inProjectDir {
        writeFile(file: path, text: content)
    }
}

String extractJiraKey(String branchName) {
    if (!branchName) {
        return null
    }

    def matcher = (branchName =~ /([A-Z][A-Z0-9]+-\d+)/)
    if (matcher.find()) {
        return matcher.group(1)
    }

    return null
}

def runNpm(String args) {
    if (isUnix()) {
        sh(script: "npm ${args}")
    } else {
        powershell(script: "npm.cmd ${args}")
    }
}

def runNpx(String args) {
    if (isUnix()) {
        sh(script: "npx ${args}")
    } else {
        powershell(script: "npx.cmd ${args}")
    }
}

def ensureDir(String path) {
    if (isUnix()) {
        sh(script: "mkdir -p ${path}")
    } else {
        powershell(script: "New-Item -ItemType Directory -Force '${path}' | Out-Null")
    }
}

def reportJiraBug(String module, String stageName, String reportFile) {
    def escapedStage = stageName.replace('"', '\\"')
    def escapedFile = reportFile.replace('"', '\\"')
    inProjectDir {
        runCmd("node automation/jira/create-jira-bug.mjs --module ${module} --stage \"${escapedStage}\" --descriptionFile \"${escapedFile}\"")
    }
}

def transitionJiraIssue(String issueKey, String statusName) {
    if (!issueKey) {
        echo "Skipping Jira transition because issue key is empty."
        return
    }

    def escapedStatus = statusName.replace('"', '\\"')
    inProjectDir {
        runCmd("node automation/jira/update-jira-status.mjs --issueKey ${issueKey} --status \"${escapedStatus}\"")
    }
}

List composeServicesForScope(String scope) {
    switch (scope) {
        case 'frontend':
            return ['guest-web', 'retailer-web', 'admin-web', 'farm-management-web', 'shipping-manager-web']
        case 'backend':
            return ['auth-service', 'admin-service', 'shipping-manager-service']
        case 'integration':
            return [
                'guest-web',
                'retailer-web',
                'admin-web',
                'farm-management-web',
                'shipping-manager-web',
                'auth-service',
                'admin-service',
                'shipping-manager-service'
            ]
        case 'infra':
        case 'all':
        default:
            return []
    }
}

String composeUpCommand(String scope) {
    def services = composeServicesForScope(scope)
    return services
        ? "docker compose up -d --build ${services.join(' ')}"
        : 'docker compose up -d --build'
}

String qaTargetsForScope(String scope) {
    def guestPort = '3405'
    def farmPort = '3402'
    def adminPort = '3401'
    def retailerPort = '3400'
    def shippingManagerPort = '3403'

    switch (scope) {
        case 'frontend':
            return "http://127.0.0.1:${guestPort}/login http://127.0.0.1:${farmPort}/health http://127.0.0.1:${adminPort}/login http://127.0.0.1:${retailerPort}/login http://127.0.0.1:${shippingManagerPort}/login"
        case 'backend':
            return 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
        case 'infra':
            return 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
        case 'integration':
        case 'all':
        default:
            return "tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:${guestPort}/login http://127.0.0.1:${farmPort}/health http://127.0.0.1:${adminPort}/login http://127.0.0.1:${retailerPort}/login http://127.0.0.1:${shippingManagerPort}/login"
    }
}

String jiraModuleForScope(String scope) {
    switch (scope) {
        case 'frontend':
            return 'frontend'
        case 'backend':
            return 'backend'
        case 'integration':
        case 'all':
            return 'integration'
        case 'infra':
        default:
            return 'infra'
    }
}

pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'QA_SCOPE',
            choices: ['all', 'frontend', 'backend', 'integration', 'infra'],
            description: 'Select the QA scope that the tester wants Jenkins to run.'
        )
        choice(
            name: 'QA_FAILURE_SCENARIO',
            choices: ['none', 'frontend_a', 'frontend_b', 'backend_a', 'backend_b'],
            description: 'Optional failure scenario to simulate a specific bug assignment during QA.'
        )
    }

    environment {
        QA_REPORT_DIR = 'qa/reports'
        QA_TARGETS = ''
        QA_DEPLOY_COMMAND = ''
        QA_SCOPE_MODULE = ''
        QA_SERVICE_LIST = ''
        QA_FAILURE_SCENARIO = "${params.QA_FAILURE_SCENARIO}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Reports') {
            steps {
                script {
                    inProjectDir {
                        ensureDir(env.QA_REPORT_DIR)
                    }
                }
            }
        }

        stage('Scope Summary') {
            steps {
                script {
                    switch (params.QA_SCOPE) {
                        case 'frontend':
                            env.QA_TARGETS = 'http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                            env.QA_DEPLOY_COMMAND = 'docker compose up -d --build guest-web retailer-web admin-web farm-management-web shipping-manager-web'
                            env.QA_SCOPE_MODULE = 'frontend'
                            env.QA_SERVICE_LIST = 'guest-web, retailer-web, admin-web, farm-management-web, shipping-manager-web'
                            break
                        case 'backend':
                            env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
                            env.QA_DEPLOY_COMMAND = 'docker compose up -d --build auth-service admin-service shipping-manager-service'
                            env.QA_SCOPE_MODULE = 'backend'
                            env.QA_SERVICE_LIST = 'auth-service, admin-service, shipping-manager-service'
                            break
                        case 'integration':
                            env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                            env.QA_DEPLOY_COMMAND = 'docker compose up -d --build guest-web retailer-web admin-web farm-management-web shipping-manager-web auth-service admin-service shipping-manager-service'
                            env.QA_SCOPE_MODULE = 'integration'
                            env.QA_SERVICE_LIST = 'guest-web, retailer-web, admin-web, farm-management-web, shipping-manager-web, auth-service, admin-service, shipping-manager-service'
                            break
                        case 'infra':
                            env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083'
                            env.QA_DEPLOY_COMMAND = 'docker compose up -d --build'
                            env.QA_SCOPE_MODULE = 'infra'
                            env.QA_SERVICE_LIST = 'full-stack'
                            break
                        case 'all':
                        default:
                            env.QA_TARGETS = 'tcp://127.0.0.1:8088 tcp://127.0.0.1:8085 tcp://127.0.0.1:8083 http://127.0.0.1:3405/login http://127.0.0.1:3402/health http://127.0.0.1:3401/login http://127.0.0.1:3400/login http://127.0.0.1:3403/login'
                            env.QA_DEPLOY_COMMAND = 'docker compose up -d --build'
                            env.QA_SCOPE_MODULE = 'integration'
                            env.QA_SERVICE_LIST = 'full-stack'
                            break
                    }

                    echo "Selected QA scope: ${params.QA_SCOPE}"
                    echo "Compose deployment: ${env.QA_DEPLOY_COMMAND}"
                    echo "Compose service set: ${env.QA_SERVICE_LIST}"
                    echo "Wait targets: ${env.QA_TARGETS}"
                    echo "Jira module for scoped infra failures: ${env.QA_SCOPE_MODULE}"
                    echo "Detected Jira key from branch: ${extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH)}"
                }
            }
        }

        stage('Mark Jira In Progress') {
            when {
                expression {
                    return extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH) != null
                }
            }
            steps {
                script {
                    def jiraKey = extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH)
                    transitionJiraIssue(jiraKey, env.JIRA_STATUS_IN_PROGRESS ?: 'In Progress')
                }
            }
        }

        stage('Deploy Test Stack') {
            steps {
                script {
                    try {
                        inProjectDir {
                            runCmd(env.QA_DEPLOY_COMMAND)
                        }
                    } catch (err) {
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/deploy-failure.txt",
                            """Stage: Deploy Test Stack
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Error: ${err}
"""
                        )
                        reportJiraBug(env.QA_SCOPE_MODULE ?: 'infra', 'Deploy Test Stack', "${env.QA_REPORT_DIR}/deploy-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Wait For Targets') {
            steps {
                script {
                    try {
                        inProjectDir {
                            runCmd("node qa/scripts/wait-for-targets.mjs ${env.QA_TARGETS}")
                        }
                    } catch (err) {
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/wait-targets-failure.txt",
                            """Stage: Wait For Targets
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Targets: ${env.QA_TARGETS}
Error: ${err}
"""
                        )
                        reportJiraBug(env.QA_SCOPE_MODULE ?: 'integration', 'Wait For Targets', "${env.QA_REPORT_DIR}/wait-targets-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Infrastructure QA') {
            when {
                expression {
                    return params.QA_SCOPE == 'infra'
                }
            }
            steps {
                script {
                    try {
                        inProjectDir {
                            runCmd('docker compose ps')
                        }
                    } catch (err) {
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/infra-failure.txt",
                            """Stage: Infrastructure QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Selected scope: ${params.QA_SCOPE}
Error: ${err}
"""
                        )
                        reportJiraBug('infra', 'Infrastructure QA', "${env.QA_REPORT_DIR}/infra-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Frontend QA') {
            when {
                expression {
                    return params.QA_SCOPE in ['all', 'frontend', 'integration']
                }
            }
            steps {
                script {
                    try {
                        inProjectDir {
                            withEnv(["QA_FAILURE_SCENARIO=${params.QA_FAILURE_SCENARIO}"]) {
                                runNpm('install --prefix clients/web-app/shipping-manager-web')
                                runNpm('run build --prefix clients/web-app/shipping-manager-web')
                                runNpm('install --prefix clients/web-app/farm-management-web')
                                runNpm('run test:smoke --prefix clients/web-app/farm-management-web')
                                runCmd('node qa/scripts/frontend-smoke.mjs')
                            }
                        }
                    } catch (err) {
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/frontend-failure.txt",
                            """Stage: Frontend QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Error: ${err}
"""
                        )
                        reportJiraBug('frontend', 'Frontend QA', "${env.QA_REPORT_DIR}/frontend-failure.txt")
                        throw err
                    }
                }
            }
        }

        stage('Backend QA') {
            when {
                expression {
                    return params.QA_SCOPE in ['all', 'backend', 'integration']
                }
            }
            steps {
                script {
                    try {
                        inProjectDir {
                            withEnv(["QA_FAILURE_SCENARIO=${params.QA_FAILURE_SCENARIO}"]) {
                                runNpx('--yes newman run qa/postman/bicap-api-smoke.postman_collection.json -e qa/postman/local.postman_environment.json --reporters cli,junit --reporter-junit-export qa/reports/newman-results.xml')
                            }
                        }
                    } catch (err) {
                        writeProjectFile(
                            "${env.QA_REPORT_DIR}/backend-failure.txt",
                            """Stage: Backend QA
Build: ${env.BUILD_URL ?: 'n/a'}
Branch: ${env.BRANCH_NAME ?: 'n/a'}
Error: ${err}
"""
                        )
                        reportJiraBug('backend', 'Backend QA', "${env.QA_REPORT_DIR}/backend-failure.txt")
                        throw err
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'BICAP-main/qa/reports/*.xml'
                }
            }
        }
    }

    post {
        success {
            script {
                def jiraKey = extractJiraKey(env.BRANCH_NAME ?: env.GIT_BRANCH)
                if (jiraKey) {
                    transitionJiraIssue(jiraKey, env.JIRA_STATUS_READY_FOR_RETEST ?: 'Ready for Retest')
                }
            }
        }
        always {
            script {
                def currentBranch = env.BRANCH_NAME ?: env.GIT_BRANCH ?: ''
                def isMainBranch = currentBranch == 'main' || currentBranch == 'origin/main' || currentBranch.endsWith('/main')

                if (isMainBranch) {
                    echo 'Skipping docker compose down on main branch to avoid stopping the shared QA stack.'
                } else {
                    try {
                        inProjectDir {
                            runCmd('docker compose down -v')
                        }
                    } catch (err) {
                        echo "docker compose down failed: ${err}"
                    }
                }
            }
            archiveArtifacts allowEmptyArchive: true, artifacts: 'BICAP-main/qa/reports/**/*'
        }
    }
}
