<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>BICAP Farm Management</title>
    <style>
        :root {
            color-scheme: light;
            font-family: "Segoe UI", Arial, sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(135deg, #f4fbf5 0%, #d9efe0 100%);
            color: #183526;
        }

        .shell {
            width: min(720px, calc(100vw - 32px));
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(24, 53, 38, 0.08);
            border-radius: 24px;
            padding: 32px;
            box-shadow: 0 24px 60px rgba(24, 53, 38, 0.12);
        }

        h1 {
            margin: 0 0 12px;
            font-size: clamp(28px, 4vw, 40px);
        }

        p {
            margin: 0 0 18px;
            line-height: 1.6;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }

        a,
        button {
            border: 0;
            border-radius: 999px;
            padding: 12px 18px;
            font-size: 15px;
            cursor: pointer;
            text-decoration: none;
        }

        .primary {
            background: #2f855a;
            color: #fff;
        }

        .secondary {
            background: #e9f5ec;
            color: #183526;
        }

        form {
            margin: 0;
        }

        .message {
            background: #ebf8f1;
            color: #1f6b43;
            border-radius: 14px;
            padding: 12px 14px;
            margin-bottom: 18px;
        }
    </style>
</head>
<body>
    <main class="shell">
        <h1>BICAP Farm Management</h1>
        <p>This web app is now streamlined for local testing and smoke verification.</p>

        <% if (typeof message !== 'undefined' && message) { %>
            <div class="message"><%= message %></div>
        <% } %>

        <% if (user) { %>
            <p>Signed in as <strong><%= user.username %></strong>.</p>
            <div class="actions">
                <a class="primary" href="/dashboard">Open dashboard</a>
                <form action="/logout" method="POST">
                    <button class="secondary" type="submit">Logout</button>
                </form>
            </div>
        <% } else { %>
            <p>Use the links below to authenticate, then continue to the dashboard and API-backed screens.</p>
            <div class="actions">
                <a class="primary" href="/login">Login</a>
                <a class="secondary" href="/register">Register</a>
                <a class="secondary" href="/health">Health check</a>
                <% if (isDevelopment) { %>
                    <a class="secondary" href="/dev/login-as-farm">Dev Login (Farm)</a>
                <% } %>
            </div>
        <% } %>
    </main>
</body>
</html>
