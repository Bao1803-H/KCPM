# Local development example.
# Copy this file to .env.local when running the farm web outside Docker.

AUTH_SERVICE_URL=http://localhost:8000/api/auth
AUTH_SERVICE_URL_UPDATE=http://localhost:8000/api/update
NODE_ENV=development
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://root:0862264719Phi@localhost:5672
FARM_API_URL=http://localhost:8000/api/farm-features
MARKETPLACE_API_PATH=http://localhost:8000/api/marketplace-products
FARMING_SEASONS_API_PATH=http://localhost:8000/api/farming-seasons
API_GATEWAY_BASE_URL=http://localhost:8000

